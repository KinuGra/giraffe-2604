aws_region         = "ap-northeast-1"
project            = "giraffe"
environment        = "dev"

db_name            = "baas_db"
db_username        = "baas_admin"
db_password        = "CHANGE_ME"
db_instance_class  = "db.t3.micro"
db_allocated_storage = 20

